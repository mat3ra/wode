{
    "name": "@mat3ra/wode",
    "version": "0.0.0",
    "description": "WOrkflow DEfinitions",
    "scripts": {
        "test": "mocha --recursive --bail --require ts-node/register 'tests/js/**/*.ts'",
        "test:coverage": "nyc --reporter=text --reporter=html --reporter=lcov mocha --recursive --bail tests/js/**/*.ts",
        "test:coverage:html": "nyc --reporter=html mocha --recursive --bail tests/js/**/*.ts",
        "test:coverage:check": "nyc --reporter=text --check-coverage mocha --recursive --bail tests/js/**/*.ts",
        "test:coverage:view": "node scripts/view-coverage.js",
        "lint": "eslint src/js tests/js && prettier --write src/js tests/js",
        "lint:fix": "eslint --fix --cache src/js tests/js && prettier --write src/js tests/js",
        "transpile": "tsc -p tsconfig-transpile.json",
        "prettier": "prettier --check src/js tests/js",
        "prepare": "husky install || exit 0",
        "generate-mixins": "ts-node scripts/generate-mixins.ts"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Exabyte-io/wode.git"
    },
    "main": "dist/js/index.js",
    "files": [
        "dist",
        "src/js",
        ".babelrc"
    ],
    "author": "Exabyte Inc.",
    "bugs": {
        "url": "https://github.com/Exabyte-io/wode/issues"
    },
    "license": "Apache-2.0",
    "homepage": "https://github.com/Exabyte-io/wode",
    "dependencies": {
        "@exabyte-io/periodic-table.js": "2022.6.8-0",
        "@types/json-schema": "^7.0.15",
        "@types/react-jsonschema-form": "^1.7.13",
        "nunjucks": "^3.2.4",
        "underscore.string": "^3.3.6"
    },
    "devDependencies": {
        "@exabyte-io/eslint-config": "2025.5.13-0",
        "@mat3ra/ade": "https://github.com/Exabyte-io/ade/archive/598ecb2ad645a21f2c96367cbbf3c2265dfb1aa9.tar.gz",
        "@mat3ra/code": "https://github.com/Exabyte-io/code/archive/b7f90fbfe37f852344cdb65520fb395a860ea274.tar.gz",
        "@mat3ra/esse": "https://github.com/Exabyte-io/esse/archive/d858d1b235eb0af35af3abae31d7df8b785417d0.tar.gz",
        "@mat3ra/ide": "https://github.com/Exabyte-io/ide/archive/9d2f11fabec9c26b3dc35113defa6b2bc0ce686d.tar.gz",
        "@mat3ra/made": "https://github.com/Exabyte-io/made/archive/bf2b904ca54b1f0f1fd3b3df9a0b5bbd2f0a9d04.tar.gz",
        "@mat3ra/mode": "https://github.com/Exabyte-io/mode/archive/5b0c40080fed20429496e5e60c69c162147c31f6.tar.gz",
        "@mat3ra/prode": "https://github.com/Exabyte-io/prode/archive/ca265ffa14b5a57247dc200bcd9e3d7d811ab8b2.tar.gz",
        "@mat3ra/standata": "https://github.com/Exabyte-io/standata/archive/833ff91af1913222a692a6f2831474f5b82a9900.tar.gz",
        "@mat3ra/tsconfig": "^2024.6.3-0",
        "@mat3ra/utils": "2025.9.20-0",
        "@types/nunjucks": "^3.2.6",
        "chai": "^4.3.4",
        "eslint": "^7.32.0",
        "eslint-config-airbnb": "^19.0.2",
        "eslint-config-prettier": "^8.5.0",
        "eslint-import-resolver-exports": "^1.0.0-beta.5",
        "eslint-import-resolver-meteor": "^0.4.0",
        "eslint-import-resolver-node": "^0.3.9",
        "eslint-plugin-import": "^2.25.3",
        "eslint-plugin-jsdoc": "^37.1.0",
        "eslint-plugin-jsx-a11y": "^6.5.1",
        "eslint-plugin-mui-path-imports": "0.0.15",
        "eslint-plugin-prettier": "^4.2.1",
        "eslint-plugin-react": "^7.30.0",
        "eslint-plugin-simple-import-sort": "^7.0.0",
        "husky": "^7.0.4",
        "lint-staged": "^12.1.2",
        "mocha": "^9.1.3",
        "nyc": "^15.1.0",
        "prettier": "^2.7.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.6.6"
    },
    "peerDependencies": {
        "@mat3ra/ade": "*",
        "@mat3ra/code": "*",
        "@mat3ra/esse": "*",
        "@mat3ra/ide": "*",
        "@mat3ra/made": "*",
        "@mat3ra/mode": "*",
        "@mat3ra/standata": "*",
        "@mat3ra/utils": "*"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "lint-staged": {
        "src/js/**/*.js": [
            "eslint --cache --fix",
            "prettier --write"
        ],
        "src/js/**/*.ts": [
            "eslint --cache --fix",
            "prettier --write"
        ],
        "tests/js/**/*.js": [
            "eslint --cache --fix",
            "prettier --write"
        ],
        "tests/js/**/*.ts": [
            "eslint --cache --fix",
            "prettier --write"
        ],
        "scripts/**/*.ts": [
            "eslint --cache --fix",
            "prettier --write"
        ]
    }
}
